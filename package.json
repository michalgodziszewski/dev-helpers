{
  "name": "custok-workflow",
  "version": "0.1.0",
  "description": "Developer automation CLI and workflow tools",
  "type": "module",
  "bin": {
    "dev": "./dist/bin/dev.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node dist/bin/dev.js",
    "test": "vitest run",
    "docs:generate": "node dist/bin/generate-cli-docs.js",
    "docs:check": "node dist/bin/generate-cli-docs.js --check",
    "verify": "npm run build && npm test && npm run docs:check"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
